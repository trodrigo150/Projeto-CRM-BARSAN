CREATE TABLE Cadastro Leads (
    
    id INT AUTO_INCREMENT PRIMARY KEY,
    NOME_DA_EMPRESA VARCHAR(255) NOT NULL,
    ENDEREÇO VARCHAR(255),
    CIDADE VARCHAR(100),
    ESTADO VARCHAR(100),
    TELEFONE VARCHAR(20),
    EMAIL VARCHAR(255) NOT NULL UNIQUE,
    INTERMEDIARIO VARCHAR(255),
    DECISOR VARCHAR(255),
    CARGO_DECISOR VARCHAR(100),
    TELEFONE_DECISOR VARCHAR(20),
    EMAIL_DECISOR VARCHAR(255) NOT NULL UNIQUE,
    OBSERVACOES TEXT,
    data_cadastro TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);